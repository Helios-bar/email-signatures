<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="MailApp">
  <Id>a1b2c3d4-e5f6-7890-1234-56789abcdef0</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Apes</ProviderName>
  <DefaultLocale>it-IT</DefaultLocale>
  <DisplayName DefaultValue="Firme Aziendali Auto" />
  <Description DefaultValue="Inserisce la firma HTML in automatico su ogni nuova email." />
  <IconUrl DefaultValue="https://raw.githubusercontent.com/Helios-bar/email-signatures/main/icona.png" />
  <HighResolutionIconUrl DefaultValue="https://raw.githubusercontent.com/Helios-bar/email-signatures/main/icona.png" />
  <SupportUrl DefaultValue="https://www.apes.it" />
  <AppDomains>
    <AppDomain>https://helios-bar.github.io</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.10" />
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://helios-bar.github.io/email-signatures/autorun.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_1">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.10">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="LaunchEvent">
            <LaunchEvents>
              <LaunchEvent Type="OnNewMessageCompose" FunctionName="inserisciFirma" />
              <LaunchEvent Type="OnMessageReply" FunctionName="inserisciFirma" />
            </LaunchEvents>
            <SourceLocation resid="AutorunFile" />
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Urls>
        <bt:Url id="AutorunFile" DefaultValue="https://helios-bar.github.io/email-signatures/autorun.html" />
      </bt:Urls>
    </Resources>
  </VersionOverrides>
</OfficeApp>